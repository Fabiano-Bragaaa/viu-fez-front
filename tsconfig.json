{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-native",
    "baseUrl": "./",
    "paths": {
      "@assets": ["./src/assets"],
      "@components": ["./src/components"],
      "@routes": ["./src/routes"],
      "@screens": ["./src/screens"],
      "@utils": ["./src/utils"],
      "@theme": ["./src/theme"],
      "@hooks": ["./src/hooks"],
      "@translate": ["./src/translate"],
      "@domain": ["./src/domain"],
      "@services": ["./src/services"],
      "@api": ["./src/api"],
      "@infra": ["./src/infra"],
      "@errors": ["./src/errors"],
      "@types": ["./src/types"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "uniwind-types.d.ts"]
}
